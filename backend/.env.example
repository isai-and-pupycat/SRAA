# ============================================================
#  Variables de entorno del backend SRAA
#  Copia este archivo como  .env  y completa los valores.
# ============================================================

# --- OPCIÓN A: LOCAL (tu PC con PostgreSQL instalado) ---
DB_USER=postgres
DB_HOST=localhost
DB_NAME=SRAA
DB_PASSWORD=1234
DB_PORT=5432

# --- OPCIÓN B: NUBE (Railway/Render) ---
# Si defines DATABASE_URL, se usa esta en lugar de las de arriba.
# Railway te la da automáticamente al crear la base de datos PostgreSQL.
# DATABASE_URL=postgresql://usuario:password@host:puerto/basededatos
# DB_SSL=true            # déjalo así en la nube; ponlo en false si tu proveedor no usa SSL

# --- Seguridad ---
JWT_SECRET=cambia_esto_por_una_clave_larga_y_secreta

# --- Puerto (la nube lo asigna sola; en local usa 5000) ---
PORT=5000
